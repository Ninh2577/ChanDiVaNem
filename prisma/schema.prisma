generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Định nghĩa các quyền người dùng
enum Role {
  ADMIN
  CTV
  READER
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  passwordHash  String
  fullName      String
  role          Role      @default(READER)
  avatarUrl     String?
  bio           String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  // Quan hệ (Relations)
  posts         Post[]    // Bài viết tác giả (CTV/Admin) đã đăng
  comments      Comment[] // Bình luận đã viết
  ratings       Rating[]  // Đánh giá đã đánh
  savedPosts    Post[]    @relation("UserSavedPosts") // Các bài viết đã lưu
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique // VD: Điểm Đến, Ẩm Thực, Văn Hóa
  slug        String   @unique
  description String?
  
  // Quan hệ Cha-Con (Hỗ trợ chuyên mục đa cấp)
  parentId    Int?
  parent      Category?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: Cascade)
  children    Category[] @relation("SubCategories")
  
  posts       Post[]
}

model Tag {
  id          Int      @id @default(autoincrement())
  name        String   @unique // VD: Hội An, Phở, Di Sản
  slug        String   @unique
  posts       Post[]
}

model Post {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  excerpt     String   @db.Text
  content     String   @db.LongText
  imageUrl    String?
  thumbnailAlt String?  // SEO: Văn bản thay thế cho ảnh đại diện
  isFeatured  Boolean  @default(false)
  isPublished Boolean  @default(false)
  viewCount   Int      @default(0)
  
  // Các trường kỹ thuật SEO (Phần chìm)
  metaTitle   String?  // Tiêu đề hiển thị trên Google
  metaDesc    String?  @db.Text // Mô tả meta (150-160 ký tự)
  canonicalUrl String? // Link gốc tránh trùng lặp
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Quan hệ
  authorId    Int
  author      User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  tags        Tag[]
  comments    Comment[]
  ratings     Rating[]
  savedBy     User[]   @relation("UserSavedPosts")
}

model Comment {
  id          Int       @id @default(autoincrement())
  content     String    @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Quan hệ với User và Post
  authorId    Int
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postId      Int
  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Bình luận lồng nhau (Nested/Reply)
  parentId    Int?
  parent      Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies     Comment[] @relation("CommentReplies")
}

model Rating {
  id          Int      @id @default(autoincrement())
  score       Int      // Điểm từ 1 đến 5
  createdAt   DateTime @default(now())

  // Quan hệ
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId      Int
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Đảm bảo mỗi user chỉ được rate 1 bài 1 lần
  @@unique([userId, postId])
}

model NewsletterSubscriber {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  subscribedAt DateTime @default(now())
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model ContributorApplication {
  id               Int               @id @default(autoincrement())
  fullName         String
  phone            String
  email            String
  portfolioLink    String
  favoriteCategory String
  experience       String            @db.Text
  status           ApplicationStatus @default(PENDING)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

// Menu điều hướng động - Admin có thể quản lý
model NavigationItem {
  id          Int     @id @default(autoincrement())
  label       String
  path        String
  order       Int
  isActive    Boolean @default(true)
  parentId    Int?
  parent      NavigationItem?  @relation("SubMenu", fields: [parentId], references: [id], onDelete: Cascade)
  children    NavigationItem[] @relation("SubMenu")
  icon        String?
  imageUrl    String?
  description String?
}

// Nội dung tĩnh toàn site — CMS đơn giản
model SiteContent {
  key       String   @id       // "home_about", "home_destinations", "home_foods"
  value     String   @db.LongText  // JSON string
  updatedAt DateTime @updatedAt
}

model AdCampaign {
  id              Int      @id @default(autoincrement())
  title           String   // Tên chiến dịch quảng cáo
  imageUrl        String   // Đường dẫn ảnh banner/popup
  targetUrl       String   // Đường dẫn liên kết khi người dùng nhấp vào
  position        String   // "POPUP_CENTER", "POPUP_BOTTOM_RIGHT", "BANNER_TOP", "BANNER_SIDEBAR"
  startDate       DateTime // Ngày bắt đầu chạy
  endDate         DateTime // Ngày kết thúc chạy
  viewCount       Int      @default(0) // Số lượt hiển thị
  clickCount      Int      @default(0) // Số lượt nhấp chuột
  contractValue   Float    @default(0) // Giá trị hợp đồng thu được (doanh thu)
  displayInterval Int      @default(5) // Thời gian trễ hiển thị (giây)
  isActive        Boolean  @default(true) // Trạng thái kích hoạt
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
